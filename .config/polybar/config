[bar/main]
width = 100%
height = 27
radius = 0
fixed-center = false

background = #161821
foreground = #d2d4de

line-size = 3
border-size = 0
padding-left = 0
padding-right = 0
margin-top = 2
module-margin-left = 0
module-margin-right = 0

font-0 = "JetBrainsMono Nerd Font Mono:size=13;1"
font-1 = "Ubuntu:size=13;1"
font-2 = "devicons:size=13;1"

modules-left = date 
modules-center = i3
modules-right = updates home volume mem wlan battery cpu-temp cpu 

tray-detached = false
tray-offset-x = 0
tray-offset-y = 0
tray-padding = 2
tray-maxsize = 200
tray-scale = 1.0
tray-position = right
tray-background = ${colors.background}
tray-foreground = ${colors.foreground}

cursor-click = pointer
cursor-scroll = ns-resize

[colors]
foreground = #d2d4de
background = #2E3440

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = true
wrapping-scroll = false

label-mode-padding = 2
label-mode-foreground = #161821
label-mode-background = #84a8c6

label-focused = %index%
label-focused-background = #84a8c6
label-focused-foreground = #161821
label-focused-padding = 2

label-unfocused = %index%
label-unfocused-background = #2E3440
label-unfocused-foreground = #d2d4de
label-unfocused-padding = 2

label-visible = %index%
label-visible-background = #84a8c6
label-visible-foreground = #2E3440
label-visible-padding = 2

label-urgent = %index%
label-urgent-background = #e27878
label-urgent-padding = 2

[module/date]
type = internal/date
interval = 5

date =
date-alt = " %Y-%m-%d"

time = %H:%M
time-alt = %H:%M:%S

format-prefix = 
format-foreground = #d2d4de
format-background = #2E3440
format-padding = 2

label = %date% %time%

[module/powermenu]
type = custom/menu

expand-right = true
format-spacing = 1

label-open = "  "
label-open-foreground = #d2d4de
label-close =  cancel
label-close-foreground = #d2d4de
label-separator = |
label-separator-foreground = #d2d4de

menu-0-0 = reboot
menu-0-0-exec = menu-open-1
menu-0-1 = power off
menu-0-1-exec = menu-open-2
menu-0-2 = log off
menu-0-2-exec = menu-open-3

menu-1-0 = cancel
menu-1-0-exec = menu-open-0
menu-1-1 = reboot
menu-1-1-exec = reboot

menu-2-0 = power off
menu-2-0-exec = poweroff
menu-2-1 = cancel
menu-2-1-exec = menu-open-0

menu-3-0 = log off
menu-3-0-exec = pkill -KILL -u $USER
menu-3-1 = cancel
menu-3-1-exec = menu-open-0

[settings]
screenchange-reload = true

[global/wm]
margin-top = 2 
margin-bottom = 2

[module/cpu-temp]
type = custom/script
exec = ~/.config/polybar/scripts/cpu-temp.sh
interval = 6
format-foreground = ${colors.foreground}
format-background = ${colors.background}

[module/mem]
type = custom/script
exec = ~/.config/polybar/scripts/mem.sh
interval = 6
format-foreground = ${colors.foreground}
format-background = ${colors.background}

[module/home]
type = custom/script
exec = ~/.config/polybar/scripts/home.sh
interval = 30
format-foreground = ${colors.foreground}
format-background = ${colors.background}

[module/updates]
type = custom/script
exec = "~/.config/polybar/scripts/packages.sh"
format = <label>
interval = 60
format-foreground = ${colors.foreground}
format-background = ${colors.background}

[module/volume]
type = custom/script
exec = "~/.config/polybar/scripts/volume.sh"
format = <label>
interval = 1
format-foreground = ${colors.foreground}
format-background = ${colors.background}

[module/cpu]
type = internal/cpu 
interval = 1 
format = <label> <ramp-coreload>
label = %percentage:3%%
format-prefix = " 龍"
ramp-coreload-spacing = 0
ramp-coreload-0 = ▁
ramp-coreload-1 = ▂
ramp-coreload-2 = ▃
ramp-coreload-3 = ▄
ramp-coreload-4 = ▅
ramp-coreload-5 = ▆
ramp-coreload-6 = ▇
ramp-coreload-7 = █
format-foreground = ${colors.foreground}
format-background = ${colors.background}

[module/battery]
type = internal/battery
format-full-foreground = ${colors.foreground}
format-full-background = ${colors.background}
format-full-suffix = "  "
format-full-prefix = " "
format-charging-foreground = ${colors.foreground}
format-charging-background = ${colors.background}
format-charging-suffix = "  "
format-charging-prefix = " "
format-discharging-foreground = ${colors.foreground}
format-discharging-background = ${colors.background}
format-discharging-suffix = " "
format-discharging-prefix = " "

format-foreground = ${colors.foreground}
format-background = ${colors.background}
full-at = 97
battery = BAT0
adapter = ADP1
poll-interval = 5

[module/wlan]
type = internal/network
interface = wlp1s0
interval = 3.0

format-connected = <ramp-signal> <label-connected>
format-connected-foreground = #d2d4de
format-connected-background = #2E3440
format-connected-padding = 2
label-connected-foreground =#d2d4de
label-connected = %essid%

format-disconnected =

ramp-signal-0 = 
ramp-signal-1 = 
ramp-signal-2 = 
ramp-signal-3 = 
ramp-signal-4 = 
ramp-signal-foreground = #d2d4de
